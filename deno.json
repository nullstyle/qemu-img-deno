{
  "name": "@nullstyle/qemu-img",
  "version": "0.2.0",
  "license": "Apache-2.0",
  "exports": {
    ".": "./mod.ts",
    "./runner": "./src/runner.ts",
    "./testing": "./testing/mod.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1"
  },
  "compilerOptions": {
    "strict": true,
    "verbatimModuleSyntax": true
  },
  "fmt": {
    "exclude": ["tests/fixtures/"]
  },
  "tasks": {
    "fmt": "deno fmt",
    "lint": "deno lint",
    "check": "deno fmt --check && deno lint && deno check .",
    "doc:lint": "deno doc --lint mod.ts src/runner.ts testing/mod.ts",
    "test": "deno test --allow-run=echo,cat,false,sleep --allow-read=tests,deno.json tests/",
    "smoke": "deno run --allow-run --allow-read --allow-write --allow-env tools/qemu_img_smoke.ts",
    "publish:check": "deno run --allow-read tools/check_publish.ts",
    "publish:dry": "deno publish --dry-run"
  },
  "publish": {
    "include": [
      "mod.ts",
      "src/**",
      "testing/**",
      "README.md",
      "CHANGELOG.md",
      "LICENSE",
      "deno.json"
    ],
    "exclude": [
      "tests/**",
      "tools/**"
    ]
  }
}
