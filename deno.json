{
  "name": "@nullstyle/qemu-img",
  "version": "0.2.1",
  "license": "Apache-2.0",
  "//exclude": "Git worktrees live under .claude/ and are gitignored, but deno does not read .gitignore — so `deno check .` would descend into every in-flight worktree and fail on somebody else's half-written code.",
  "exclude": [".claude/"],
  "exports": {
    ".": "./mod.ts",
    "./runner": "./src/runner.ts",
    "./recipe": "./src/recipe/mod.ts",
    "./fs": "./src/fs/mod.ts",
    "./system": "./src/system/mod.ts",
    "./testing": "./testing/mod.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1"
  },
  "compilerOptions": {
    "strict": true,
    "verbatimModuleSyntax": true
  },
  "fmt": {
    "exclude": ["tests/fixtures/"]
  },
  "tasks": {
    "fmt": "deno fmt",
    "lint": "deno lint",
    "check": "deno fmt --check && deno lint && deno check .",
    "doc:lint": "deno doc --lint mod.ts src/runner.ts src/recipe/mod.ts src/fs/mod.ts src/system/mod.ts testing/mod.ts",
    "test": "deno test --allow-run=echo,cat,false,sleep,sh --allow-read=tests,deno.json --allow-write=tests/.tmp tests/",
    "smoke": "deno run --allow-run --allow-read --allow-write --allow-env tools/qemu_img_smoke.ts",
    "smoke:recipe": "deno run --allow-run --allow-read --allow-write --allow-env tools/recipe_smoke.ts",
    "appliance": "deno run --allow-run=bsdtar,sh --allow-read --allow-write --allow-net=dl-cdn.alpinelinux.org tools/build_appliance.ts",
    "smoke:system": "deno run --allow-run --allow-read --allow-write --allow-env tools/system_smoke.ts",
    "smoke:cloud": "deno run --allow-run --allow-read --allow-write --allow-env --allow-net=dl-cdn.alpinelinux.org tools/cloud_smoke.ts",
    "appliance:run": "deno run --allow-run --allow-read --allow-write tools/appliance_run.ts",
    "publish:check": "deno run --allow-read tools/check_publish.ts",
    "publish:dry": "deno publish --dry-run"
  },
  "publish": {
    "include": [
      "mod.ts",
      "src/**",
      "testing/**",
      "README.md",
      "CHANGELOG.md",
      "LICENSE",
      "deno.json"
    ],
    "exclude": [
      "tests/**",
      "tools/**"
    ]
  }
}
